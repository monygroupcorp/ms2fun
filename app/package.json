{
  "name": "ms2fun-app",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "lint": "eslint . && stylelint \"src/**/*.css\"",
    "lint:css": "stylelint \"src/**/*.css\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --grep-invert @archive",
    "test:e2e:archive": "playwright test --grep @archive",
    "wagmi:generate": "wagmi generate",
    "chain:fork": "bash scripts/dev-chain/fork.sh",
    "chain:deploy": "tsx scripts/dev-chain/deploy.ts",
    "chain:stop": "bash scripts/dev-chain/stop.sh"
  },
  "dependencies": {
    "@tanstack/query-sync-storage-persister": "^5.101.2",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-query-persist-client": "^5.101.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "viem": "^2.53.1",
    "wagmi": "^3.6.18",
    "wouter": "^3.10.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@wagmi/cli": "^2.10.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-declaration-strict-value": "^1.11.1",
    "tsx": "^4.20.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "^0.28.0"
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
